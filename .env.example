DISCORD_WEBHOOK1=https://discord.com/api/webhooks/YOUR_WEBHOOK_URL
DISCORD_WEBHOOK2=https://discord.com/api/webhooks/YOUR_WEBHOOK_URL
TELEGRAM_TOKEN=put_your_token_here
# one chat, or several separated by commas
TELEGRAM_CHAT_ID=123456789
# TELEGRAM_CHAT_ID=123456789,987654321
# optional: keep Render awake
# HEALTH_PING_URL=https://notices-bot.onrender.com

# optional local folder for JSON / posted.txt (default: current dir)
# DATA_DIR=/data

# Render free has no disk — back up state to a secret GitHub Gist:
# 1) Create a secret gist with one file bot_state.json content: {}
# 2) Create a fine-grained or classic token with gist scope
# GITHUB_TOKEN=ghp_...
# STATE_GIST_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
